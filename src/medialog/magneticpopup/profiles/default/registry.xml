<?xml version="1.0"?>
<registry>

  <records
      interface="medialog.magneticpopup.interfaces.IMagneticPopupSettings">
      <value key="image_size">large</value>
      <value key="popup_classes">
        img.image-popup,
        figure:not(.no-pop-up) img,
        img.image-inline,
        img.image-left,
        img.image-right
      </value>
  </records>


  <records
      interface="plone.base.interfaces.resources.IBundleRegistry"
      prefix="plone.bundles/magnetikpopup">

      <value key="enabled">True</value>

      <!-- LOAD BOTH FILES -->
      <value key="jscompilation">++plone++magneticpopup/jquery.magnific-popup-min.js</value> 

      <value key="load_async">False</value>
      <value key="load_defer">False</value>
      <value key="depends">plone</value>
      <value key="compile">False</value>

  </records>


  <records
      interface="plone.base.interfaces.resources.IBundleRegistry"
      prefix="plone.bundles/magneticpopup">
      <value key="enabled">True</value>
      <!-- LOAD BOTH FILES -->
      <value key="jscompilation"> ++plone++magneticpopup/magnetic-popup.js</value>
      <value key="csscompilation">++plone++magneticpopup/magnetic-popup.css</value>

      <value key="load_async">False</value>
      <value key="load_defer">False</value>
      <value key="depends">magnetikpopup</value>
      <value key="compile">False</value>

  </records>

</registry>